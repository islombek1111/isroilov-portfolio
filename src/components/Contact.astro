---
// Contact.astro
// Update the social links below with your real usernames
---

<section id="contact" class="min-h-screen flex flex-col justify-center px-6 md:px-12 py-24 md:py-32 relative overflow-hidden">

  <!-- Ambient glow -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[350px] rounded-full blur-[130px]"
      style="background:rgba(255,255,255,0.018);"></div>
  </div>

  <div class="max-w-7xl mx-auto w-full relative z-10">

    <!-- Header -->
    <div class="flex items-center gap-4 mb-4 section-reveal">
      <span class="w-8 h-px bg-white/25"></span>
      <span class="font-mono text-[10px] tracking-[0.35em] uppercase text-white/25">Get In Touch</span>
    </div>

    <h2 class="font-display font-light text-5xl md:text-7xl tracking-widest text-white mb-6 section-reveal" style="animation-delay:0.1s">
      Say Hello.
    </h2>

    <p class="font-body font-light text-white/38 text-base md:text-lg max-w-md mb-16 leading-relaxed section-reveal" style="animation-delay:0.2s">
      No forms, no fuss. Just reach out directly — I read everything.
    </p>

    <!-- Email -->
    <div class="section-reveal mb-16" style="animation-delay:0.3s">
      <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/22 mb-3">Email</p>
      <a href="mailto:hello@isroilov.com" data-hover
        class="group inline-flex items-center gap-4 font-display font-light text-2xl md:text-4xl text-white/65 hover:text-white transition-colors duration-300">
        hello@isroilov.com
        <span class="text-white/18 group-hover:text-white/55 group-hover:translate-x-2 transition-all duration-300 text-2xl">→</span>
      </a>
    </div>

    <!-- Divider -->
    <div class="h-px bg-white/5 mb-14 section-reveal" style="animation-delay:0.35s"></div>

    <!-- Social pills -->
    <div class="section-reveal" style="animation-delay:0.4s">
      <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-white/22 mb-8">Find Me Here</p>
      <div class="flex flex-wrap gap-4">

        <!-- Instagram — update href to your real handle -->
        <a href="https://instagram.com/isroilcv" target="_blank" rel="noopener noreferrer" data-hover class="social-pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
          </svg>
          Instagram
        </a>

        <!-- X / Twitter — update href -->
        <a href="https://x.com/isroilcv" target="_blank" rel="noopener noreferrer" data-hover class="social-pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          X (Twitter)
        </a>

        <!-- Facebook — update href -->
        <a href="https://facebook.com/isroilcv" target="_blank" rel="noopener noreferrer" data-hover class="social-pill">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Facebook
        </a>

      </div>
    </div>

    <!-- Footer -->
    <div class="mt-24 pt-8 border-t border-white/5 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 section-reveal" style="animation-delay:0.5s">
      <span class="font-mono text-[10px] tracking-[0.25em] uppercase text-white/12">
        © {new Date().getFullYear()} Isroilov
      </span>
      <span class="font-mono text-[10px] tracking-[0.25em] uppercase text-white/12">
        Budapest · Tashkent
      </span>
    </div>

  </div>
</section>

<style>
  .social-pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 22px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 9999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.42);
    text-decoration: none;
    transition: all 0.3s ease;
    background: transparent;
  }
  .social-pill:hover {
    border-color: rgba(255,255,255,0.28);
    color: rgba(255,255,255,0.88);
    background: rgba(255,255,255,0.04);
    transform: translateY(-2px);
  }
</style>

<script>
  const els = document.querySelectorAll('#contact .section-reveal');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.animationPlayState = 'running';
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });
  els.forEach(el => obs.observe(el));
</script>
