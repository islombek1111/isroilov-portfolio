---
// Hero.astro
import MosaicReveal from './MosaicReveal.astro';
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />

<section id="home" class="relative min-h-screen flex flex-col justify-end pb-16 md:pb-24 px-6 md:px-12 overflow-hidden">

  <!-- Background photo -->
  <div class="absolute inset-0 z-0">
    <MosaicReveal
         src="/images/hero.jpg"
        delay={1800}
        cols={13}
        rows={13}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-transparent to-transparent"></div>
  </div>

  <!-- Vertical decorative line -->
  <div class="absolute left-6 md:left-12 top-0 bottom-0 w-px z-10 overflow-hidden" aria-hidden="true">
    <div class="vert-line"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto w-full">

    <!-- Eyebrow -->
    <div class="flex items-center gap-4 mb-6 anim-fade-up" style="--delay:0.3s">
      <span class="w-8 h-px bg-white/35"></span>
      <span class="font-mono text-[10px] tracking-[0.35em] uppercase text-white/35">Islombek Isroilov</span>
    </div>


    <!-- Collapsible note card -->
    <div class="note-card anim-fade-up" style="--delay:1.4s; max-width: 480px;" id="noteCard">

      <!-- Collapsed header — always visible -->
      <button class="note-header" id="noteToggle" aria-expanded="false" aria-controls="noteBody">
        <div class="note-accent-bar"></div>
        <div class="note-header-inner">
          <span class="note-title">No portfolio fluff here.</span>
          <div class="note-chevron" id="noteChevron">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2.5 4.5L6 8L9.5 4.5" stroke="rgba(255,255,255,0.35)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </button>

      <!-- Expandable body -->
      <div class="note-body" id="noteBody" aria-hidden="true">
        <div class="note-body-inner">
          <p class="note-text" id="noteText"></p>
          <span class="note-cursor" id="noteCursor" aria-hidden="true">|</span>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px w-full bg-white/5 mt-10 mb-10 overflow-hidden">
      <div class="divider-line" style="--delay:1.6s"></div>
    </div>

    <!-- CTAs -->
    <div class="flex items-center gap-5 anim-fade-up" style="--delay:1.7s">
      <a href="#dashboard" data-hover class="btn-glow px-7 py-3 text-xs tracking-[0.25em] uppercase font-body rounded-full">
        See My Stuff
      </a>
      <a href="#contact" data-hover
        class="btn-glow hidden md:inline-flex items-center gap-2 px-5 py-2.5 text-xs tracking-[0.2em] uppercase font-body rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-white/60 animate-pulse"></span>
        Say Hello
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-6 md:right-12 z-10 flex flex-col items-center gap-3 anim-fade-up" style="--delay:2.0s">
    <span class="font-mono text-[9px] tracking-[0.3em] uppercase text-white/22" style="writing-mode:vertical-lr;">Scroll</span>
    <div class="w-px h-12 overflow-hidden" style="background: linear-gradient(to bottom, rgba(255,255,255,0.18), transparent);">
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  @keyframes lineGrow   { to { height: 100%; } }
  @keyframes lineExpand { to { width: 100%; } }
  @keyframes scrollAnim { 0%{top:-30%} 100%{top:130%} }
  @keyframes fadeUp { from { opacity:0; transform:translateY(22px); } to { opacity:1; transform:translateY(0); } }
  @keyframes nameReveal {
    0%   { opacity: 0; transform: translateY(32px); filter: blur(4px); }
    60%  { filter: blur(0px); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0px); }
  }
  @keyframes cursorBlink { 0%,100%{opacity:1} 50%{opacity:0} }
  @keyframes accentPulse { 0%,100%{opacity:.3} 50%{opacity:.65} }

  .hero-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 0.08em;
    color: white;
    opacity: 0;
    animation: nameReveal 1.6s 0.5s cubic-bezier(0.16,1,0.3,1) forwards;
    display: block;
    will-change: transform, opacity, filter;
  }

  .anim-fade-up {
    opacity: 0;
    animation: fadeUp 1s var(--delay, 0s) cubic-bezier(0.16,1,0.3,1) forwards;
  }

  .vert-line {
    height: 0%; width: 100%;
    background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.18), transparent);
    animation: lineGrow 2s 0.5s cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .divider-line {
    height: 100%; width: 0%;
    background: linear-gradient(to right, rgba(255,255,255,0.28), rgba(255,255,255,0.08), transparent);
    animation: lineExpand 1.5s var(--delay, 0s) cubic-bezier(0.16,1,0.3,1) forwards;
  }
  .scroll-line {
    width: 100%; height: 30%; background: rgba(255,255,255,0.6);
    animation: scrollAnim 2s 2.4s ease-in-out infinite;
    top: -30%; position: relative;
  }

  /* ── Note card ─────────────────────────────────────────── */
  .note-card {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    background: rgba(255,255,255,0.028);
    backdrop-filter: blur(6px);
    overflow: hidden;
  }

  .note-header {
    width: 100%;
    display: flex;
    align-items: stretch;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }
  .note-header:hover .note-title { color: rgba(255,255,255,0.85); }

  .note-accent-bar {
    width: 3px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.32);
    animation: accentPulse 4s ease-in-out infinite;
  }

  .note-header-inner {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    gap: 12px;
  }

  .note-title {
    font-family: 'Lexend', sans-serif;
    font-weight: 400;
    font-size: clamp(0.75rem, 1.35vw, 0.875rem);
    color: rgba(255,255,255,0.78);
    letter-spacing: 0.01em;
    line-height: 1.3;
    transition: color 0.25s ease;
  }

  .note-chevron {
    flex-shrink: 0;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
  }
  .note-chevron.open { transform: rotate(180deg); }

  /* Body — height animates via max-height trick */
  .note-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.16,1,0.3,1), opacity 0.35s ease;
    opacity: 0;
  }
  .note-body.open {
    max-height: 200px;
    opacity: 1;
  }

  .note-body-inner {
    padding: 0 16px 16px 19px; /* 19px aligns with text after accent bar */
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .note-text {
    font-family: 'Lexend', sans-serif;
    font-weight: 200;
    font-size: clamp(0.68rem, 1.15vw, 0.78rem);
    color: rgba(255,255,255,0.38);
    line-height: 1.68;
    letter-spacing: 0.01em;
    margin: 0;
    display: inline;
  }

  .note-cursor {
    font-family: 'Lexend', sans-serif;
    font-size: clamp(0.68rem, 1.15vw, 0.78rem);
    color: rgba(255,255,255,0.55);
    animation: cursorBlink 0.85s step-end infinite;
    display: inline;
    margin-left: 1px;
  }
  .note-cursor.done { display: none; }

  .warning-domain-link {
    font-family: 'Lexend', sans-serif;
    font-weight: 400;
    font-size: inherit;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.04em;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.28);
    padding-bottom: 1px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .warning-domain-link:hover {
    color: rgba(255,255,255,1);
    border-bottom-color: rgba(255,255,255,0.7);
  }
</style>

<script>
// ── Typewriter with mechanical keyboard audio ────────────────

// The text to type. Uses a special marker {link} for the isroilov.com anchor.
const FULL_TEXT_PARTS = [
  { text: "This is just a space where I add, change, or nuke stuff whenever I feel like it. " },
  { link: true,  text: "isroilov.com" },
  { text: " is not a reflection of who I am or what I do." },
];

// Build full char array for the typewriter (link chars get a flag)
type CharEntry = { char: string; isLink: boolean };
const chars: CharEntry[] = [];
for (const part of FULL_TEXT_PARTS) {
  for (const char of part.text) {
    chars.push({ char, isLink: !!part.link });
  }
}

// Web Audio API — generate a realistic mechanical click per keystroke
function createAudioCtx(): AudioContext | null {
  try {
    return new (window.AudioContext || (window as any).webkitAudioContext)();
  } catch { return null; }
}

let audioCtx: AudioContext | null = null;

function playKeyClick() {
  if (!audioCtx) audioCtx = createAudioCtx();
  if (!audioCtx) return;
  const ctx = audioCtx;
  if (ctx.state === "suspended") ctx.resume();

  const bufSize = ctx.sampleRate * 0.045;
  const buffer = ctx.createBuffer(1, bufSize, ctx.sampleRate);
  const data = buffer.getChannelData(0);

  // Noise burst with fast decay — mechanical feel
  for (let i = 0; i < bufSize; i++) {
    const t = i / ctx.sampleRate;
    const noise = (Math.random() * 2 - 1);
    const decay = Math.exp(-t * 140);
    const click = Math.exp(-t * 600) * 0.6;
    data[i] = (noise * decay + click) * 0.22;
  }

  const source = ctx.createBufferSource();
  source.buffer = buffer;

  // Bandpass — gives it the "keycap thock"
  const bpf = ctx.createBiquadFilter();
  bpf.type = "bandpass";
  bpf.frequency.value = 2200 + Math.random() * 600;
  bpf.Q.value = 0.8;

  // Slight gain variation per key
  const gain = ctx.createGain();
  gain.gain.value = 0.7 + Math.random() * 0.3;

  source.connect(bpf);
  bpf.connect(gain);
  gain.connect(ctx.destination);
  source.start();
  source.stop(ctx.currentTime + 0.05);
}

// ── DOM refs ────────────────────────────────────────────────
const toggle  = document.getElementById("noteToggle");
const body    = document.getElementById("noteBody");
const chevron = document.getElementById("noteChevron");
const textEl  = document.getElementById("noteText") as HTMLParagraphElement;
const cursor  = document.getElementById("noteCursor");

let typed = false;
let typing = false;

function startTyping() {
  if (typed || typing) return;
  typing = true;

  let i = 0;
  // Build incrementally into textEl
  textEl.innerHTML = "";

  // Create the link node upfront (hidden), revealed char by char
  let linkSpan: HTMLAnchorElement | null = null;
  let plainNode: Text | null = null;

  function nextChar() {
    if (i >= chars.length) {
      typing = false;
      typed = true;
      cursor?.classList.add("done");
      return;
    }

    const entry = chars[i];
    i++;

    // Occasional tiny variance in speed for realism
    const delay = entry.char === " " ? 40 + Math.random() * 30
                : entry.char === "." ? 80 + Math.random() * 40
                : 28 + Math.random() * 28;

    if (entry.char !== " " && entry.char !== "\n") playKeyClick();

    if (entry.isLink) {
      // Create/reuse link span
      if (!linkSpan) {
        linkSpan = document.createElement("a");
        linkSpan.href = "https://isroilov.com";
        linkSpan.className = "warning-domain-link";
        linkSpan.target = "_blank";
        linkSpan.rel = "noopener noreferrer";
        plainNode = null; // reset so next plain chars create new text node
        textEl.appendChild(linkSpan);
      }
      linkSpan.textContent = (linkSpan.textContent || "") + entry.char;
    } else {
      linkSpan = null; // next char is plain
      // Reuse or create trailing text node
      const lastChild = textEl.lastChild;
      if (lastChild && lastChild.nodeType === Node.TEXT_NODE) {
        lastChild.textContent += entry.char;
      } else {
        textEl.appendChild(document.createTextNode(entry.char));
      }
    }

    setTimeout(nextChar, delay);
  }

  nextChar();
}

// ── Toggle open/close ────────────────────────────────────────
let open = false;

toggle?.addEventListener("click", () => {
  open = !open;
  toggle.setAttribute("aria-expanded", String(open));
  body?.setAttribute("aria-hidden", String(!open));

  if (open) {
    body?.classList.add("open");
    chevron?.classList.add("open");
    // Small delay so the panel slides open before typing starts
    setTimeout(startTyping, 280);
  } else {
    body?.classList.remove("open");
    chevron?.classList.remove("open");
  }
});
</script>
