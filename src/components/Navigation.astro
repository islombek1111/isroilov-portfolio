---
// Navigation.astro
import SlideButton from './SlideButton.jsx';
---

<header id="nav" class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-6">
  <div id="nav-backdrop" class="absolute inset-0 transition-all duration-500 pointer-events-none"></div>

  <nav class="relative max-w-7xl mx-auto flex items-center justify-between">

    <!-- Logo -->
    <a href="#home" class="group flex items-center gap-3" data-hover>
      <div class="w-7 h-7 relative flex items-center justify-center">
        <div class="absolute w-full h-full border border-white/40 rotate-45 group-hover:rotate-[135deg] transition-transform duration-700"></div>
        <div class="w-1.5 h-1.5 bg-white rounded-full"></div>
      </div>
      <span class="font-display text-lg tracking-[0.2em] text-white/90 group-hover:text-white transition-colors duration-300">
        ISROILOV
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-10">
      {[
        { label: 'Pics',  href: '#pics'  },
        { label: 'Books', href: '#books' },
        { label: 'Certs', href: '#certs' },
        { label: 'Notes', href: '#notes' },
      ].map(({ label, href }) => (
        <li>
          <a href={href} data-hover
            class="relative group font-body text-xs tracking-[0.25em] uppercase text-white/45 hover:text-white transition-colors duration-300 py-1">
            {label}
            <span class="absolute bottom-0 left-0 h-px bg-white w-0 group-hover:w-full transition-all duration-500"></span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Say Hello -->
    <a href="#contact" data-hover
      class="btn-glow hidden md:inline-flex items-center gap-2 px-5 py-2.5 text-xs tracking-[0.2em] uppercase font-body rounded-full">
      <span class="w-1.5 h-1.5 rounded-full bg-white/60 animate-pulse"></span>
      Say Hello
    </a>

      <SlideButton client:load />

    <!-- Mobile hamburger -->
    <button id="menu-toggle" data-hover aria-label="Open menu" class="md:hidden flex flex-col gap-1.5 p-2">
      <span class="ham-line w-6 h-px bg-white transition-all duration-300 origin-center block"></span>
      <span class="ham-line w-4 h-px bg-white transition-all duration-300 origin-center block"></span>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div id="mobile-menu"
    class="md:hidden absolute top-full left-0 right-0 bg-black/96 backdrop-blur-xl border-t border-white/5
           px-6 py-8 flex flex-col gap-6 translate-y-[-10px] opacity-0 pointer-events-none transition-all duration-300">
    {[
      { label: 'Pics',  href: '#pics'  },
      { label: 'Books', href: '#books' },
      { label: 'Certs', href: '#certs' },
      { label: 'Notes', href: '#notes' },
    ].map(({ label, href }) => (
      <a href={href} class="font-display text-2xl text-white/55 hover:text-white tracking-widest transition-colors mobile-link">
        {label}
      </a>
    ))}
    <a href="#contact" class="mt-4 btn-glow justify-center px-5 py-3 text-xs tracking-[0.2em] uppercase font-body rounded-full w-full">
      Say Hello
    </a>
  </div>
</header>

<script>
  // Scroll → frosted backdrop
  const backdrop = document.getElementById('nav-backdrop');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      backdrop?.setAttribute('style', 'background:rgba(0,0,0,0.72);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,0.05)');
    } else {
      backdrop?.setAttribute('style', '');
    }
  });

  // Mobile toggle
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const lines  = document.querySelectorAll('.ham-line');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (open) {
      menu?.classList.remove('translate-y-[-10px]','opacity-0','pointer-events-none');
      menu?.classList.add('translate-y-0','opacity-100');
      lines[0]?.classList.add('rotate-45','translate-y-[7px]');
      lines[1]?.classList.add('-rotate-45','-translate-y-[1px]','!w-6');
    } else {
      menu?.classList.add('translate-y-[-10px]','opacity-0','pointer-events-none');
      menu?.classList.remove('translate-y-0','opacity-100');
      lines[0]?.classList.remove('rotate-45','translate-y-[7px]');
      lines[1]?.classList.remove('-rotate-45','-translate-y-[1px]','!w-6');
    }
  });

  document.querySelectorAll('.mobile-link').forEach(l => {
    l.addEventListener('click', () => {
      open = false;
      menu?.classList.add('translate-y-[-10px]','opacity-0','pointer-events-none');
      menu?.classList.remove('translate-y-0','opacity-100');
    });
  });
</script>
