---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import FannedGallery from '../components/FannedGallery.jsx';
import Books from '../components/Books.jsx';
import Certs from '../components/Certs.jsx';
import Contact from '../components/Contact.astro';
---

<BaseLayout>
  <Navigation />
  <Hero />

  <!-- PICS section -->
  <FannedGallery client:load />

  <!-- BOOKS placeholder -->
 <Books client:visible />

  <!-- CERTS placeholder -->
<Certs client:visible />

  <!-- NOTES placeholder -->
  <section id="notes" class="min-h-screen flex items-center justify-center px-6 md:px-12">
    <div class="text-center">
      <p class="font-mono text-xs tracking-[0.3em] uppercase text-white/12 mb-4">Coming Next</p>
      <h2 class="font-display text-5xl md:text-7xl font-light tracking-widest text-white/8">Notes</h2>
    </div>
  </section>

  <Contact />
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@200;300;400&display=swap');

  /* Global Scrollbar Hiding */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Necessary for 3D flip */
  .perspective-1000 {
    perspective: 1000px;
  }

  html {
    background-color: black;
    color: white;
    scroll-behavior: smooth;
  }
</style>