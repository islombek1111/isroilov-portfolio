---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import FannedGallery from '../components/FannedGallery.jsx';
import Books from '../components/Books.jsx';
import Certs from '../components/Certs.jsx';
import Stack from '../components/Stack.jsx';
import Contact from '../components/Contact.astro';
---

<BaseLayout>
  <Navigation />
  <Hero />

  <!-- PICS section -->
  <FannedGallery client:load />

  <!-- BOOKS section -->
  <Books client:visible />

  <!-- CERTS section -->
  <Certs client:visible />

  <!-- STACK section (replaces Notes) -->
  <Stack client:visible />

  <Contact />
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@200;300;400&display=swap');

  /* Global Scrollbar Hiding */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  /* Necessary for 3D flip */
  .perspective-1000 { perspective: 1000px; }

  html {
    background-color: black;
    color: white;
    scroll-behavior: smooth;
  }
</style>
