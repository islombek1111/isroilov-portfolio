---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import FannedGallery from '../components/FannedGallery.jsx';
import Books from '../components/Books.jsx';
import Contact from '../components/Contact.astro';
---

<BaseLayout>
  <Navigation />
  <Hero />

  <!-- PICS — 3D fanned gallery (React component) -->
  <FannedGallery client:load />

  <!-- BOOKS placeholder — we'll build this next -->
 <Books client:visible />

  <!-- CERTS placeholder -->
  <section id="certs" class="min-h-screen flex items-center justify-center px-6 md:px-12">
    <div class="text-center">
      <p class="font-mono text-xs tracking-[0.3em] uppercase text-white/12 mb-4">Coming Next</p>
      <h2 class="font-display text-5xl md:text-7xl font-light tracking-widest text-white/8">Certs</h2>
    </div>
  </section>

  <!-- NOTES placeholder -->
  <section id="notes" class="min-h-screen flex items-center justify-center px-6 md:px-12">
    <div class="text-center">
      <p class="font-mono text-xs tracking-[0.3em] uppercase text-white/12 mb-4">Coming Next</p>
      <h2 class="font-display text-5xl md:text-7xl font-light tracking-widest text-white/8">Notes</h2>
    </div>
  </section>

  <Contact />
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Lexend:wght@300;400&display=swap');

  /* Global scrollbar hiding for specific elements */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  html, body {
    background-color: black;
    color: white;
    overflow-x: hidden;
  }

  /* Keep site transitions smooth */
  section {
    position: relative;
    z-index: 1;
  }

 .perspective-1000 {
    perspective: 1000px;
  }

  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  /* Ensure Lexend is used throughout */
  .font-lexend {
    font-family: 'Lexend', sans-serif;
  }
</style>